# Server Configuration
PORT=3001
NODE_ENV=development

# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Your app name and URL (optional, for OpenRouter rankings)
APP_NAME=DocuMind-Insight
APP_URL=http://localhost:5173

# Embedding Model Configuration
# OpenRouter model format: provider/model-name
# Options: openai/text-embedding-3-small, openai/text-embedding-ada-002
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# LLM Model Configuration
# Popular options:
# - openai/gpt-4o-mini (cheap, fast)
# - openai/gpt-4-turbo (more powerful)
# - anthropic/claude-3.5-sonnet (excellent quality)
# - google/gemini-pro-1.5 (good balance)
# - meta-llama/llama-3.1-8b-instruct:free (FREE!)
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.7
MAX_TOKENS=2000

# Vector Database Configuration
CHROMA_PATH=./chroma_db
COLLECTION_NAME=documind_docs

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
# Max file size in bytes (10MB = 10 * 1024 * 1024)

# CORS Configuration
FRONTEND_URL=http://localhost:5173
